   "cell_type": "markdown",
   "id": "e99473ba",
   "metadata": {},
   "source": [
    "# Centralized Machine Learning Unlearning Evaluation\n",
    "\n",
    "This notebook evaluates machine unlearning in a centralized setting:\n",
    "- **Exact unlearning**: Retrain model from scratch on retain set only\n",
    "- **Approximate unlearning**: Gradient-ascent method on delete set\n",
    "- **Evaluation**: Forgetting effectiveness, utility preservation, privacy leakage (MIA)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "1f43dcf7",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================================\n",
    "# DATA LOADING & SPLITTING\n",
    "# ============================================================================\n",
    "\n",
    "# Use standard MNIST preprocessing\n",
    "transform = transforms.Compose([\n",
    "    transforms.ToTensor(),\n",
    "    transforms.Normalize((0.1307,), (0.3081,))  # MNIST mean/std\n",
    "])\n",
    "\n",
    "print(\"Loading MNIST dataset...\")\n",
    "train_dataset = datasets.MNIST(root='./data', train=True, download=True, transform=transform)\n",
    "test_dataset = datasets.MNIST(root='./data', train=False, download=True, transform=transform)\n",
    "\n",
    "print(f\"\\nTotal training data: {len(train_dataset)}\")\n",
    "print(f\"Total test data: {len(test_dataset)}\")\n",
    "\n",
    "# Split training data: retain (95%) and delete (5%)\n",
    "num_delete = int(0.05 * len(train_dataset))\n",
    "num_retain = len(train_dataset) - num_delete\n",
    "\n",
    "indices = np.random.permutation(len(train_dataset))\n",
    "delete_idx = indices[:num_delete]\n",
    "retain_idx = indices[num_delete:]\n",
    "\n",
    "retain_set = Subset(train_dataset, retain_idx)\n",
    "delete_set = Subset(train_dataset, delete_idx)\n",
    "\n",
    "print(f\"\\nTrain split:\")\n",
    "print(f\"  Retain set (keep): {len(retain_set)} samples (95%)\")\n",
    "print(f\"  Delete set (forget): {len(delete_set)} samples (5%)\")\n",
    "\n",
    "# Create dataloaders\n",
    "retain_loader = DataLoader(retain_set, batch_size=64, shuffle=True, num_workers=0)\n",
    "delete_loader = DataLoader(delete_set, batch_size=64, shuffle=True, num_workers=0)\n",
    "test_loader = DataLoader(test_dataset, batch_size=64, shuffle=False, num_workers=0)\n",
    "\n",
    "print(f\"\\nHoldout test set: {len(test_dataset)} samples (for final evaluation)\")\n",
    "\n",
    "<VSCode.Cell id=\"#VSC-4bb445b2\" language=\"python\">\n",
    "print(f\"Total dataset size: {len(dataset)}\")\n",
    "print(f\"Retain set size: {len(retain_set)}\")\n",
    "print(f\"Delete set size: {len(delete_set)}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "3f3bd95c",
   "metadata": {},
   "outputs": [],
   "source": [
    "# ============================================================================\n",
    "# MODEL DEFINITION\n",
    "# ============================================================================\n",
    "\n",
    "<VSCode.Cell id=\"#VSC-fc2ef6f4\" language=\"python\">\n",
    "class SimpleCNN(nn.Module):\n",
    "    def __init__(self):\n",
    "        super().__init__()\n",
    "        self.net = nn.Sequential(\n",
    "            nn.Conv2d(1, 32, 3, 1),\n",
    "            nn.ReLU(),\n",
    "            nn.MaxPool2d(2),\n",
    "            nn.Flatten(),\n",
    "            nn.Linear(5408, 10)\n",
    "        )\n",
    "\n",
    "    def forward(self, x):\n",
    "        return self.net(x)\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 9,
