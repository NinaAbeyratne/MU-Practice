    "# Final ACCURACY evaluations on both models\n",
    "\n",
    "# Approx model accuracies (after gradient ascent)\n",
    "approx_delete_acc, approx_delete_loss_final = evaluate(approx_model, delete_loader, device=device)\n",
    "approx_retain_acc, approx_retain_loss_final = evaluate(approx_model, retain_loader, device=device)\n",
    "\n",
    "print(f\"Approx model - Delete accuracy: {approx_delete_acc:.4f}, loss: {approx_delete_loss_final:.4f}\")\n",
    "print(f\"Approx model - Retain accuracy: {approx_retain_acc:.4f}, loss: {approx_retain_loss_final:.4f}\")\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "7d4c38ca",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Exact model (retrained from scratch) accuracies for comparison\n",
    "exact_delete_acc, exact_delete_loss_final = evaluate(exact_model, delete_loader, device=device)\n",
    "exact_retain_acc, exact_retain_loss_final = evaluate(exact_model, retain_loader, device=device)\n",
    "\n",
    "print(f\"Exact model - Delete accuracy: {exact_delete_acc:.4f}, loss: {exact_delete_loss_final:.4f}\")\n",
    "print(f\"Exact model - Retain accuracy: {exact_retain_acc:.4f}, loss: {exact_retain_loss_final:.4f}\")\n"
   ]
