    "print(f\"  Reduction:             {non_member_conf_improvement:+.4f}  ← {'✓ BETTER (less confidence on forgotten data)' if non_member_conf_improvement > 0 else '✗ WORSE'}\")\n",
    "print(f\"  Member confidence:     {mia_before['member_mean_confidence']:.4f} → {mia_after['member_mean_confidence']:.4f}\")\n"
